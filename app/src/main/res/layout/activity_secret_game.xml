<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/game_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    tools:context=".screens.SecretGameActivity">

    <!-- ===== TOP BAR: SCORE & SONG INFO ===== -->
    <View
        android:id="@+id/top_bar_bg"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/background_red"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_game_song_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:text="Song Name"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_bar_bg" />

    <TextView
        android:id="@+id/tv_game_accuracy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="4dp"
        android:text="Acc: 100%"
        android:textColor="#FFEB3B"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_game_song_name" />

    <!-- ===== PROGRESS BAR (Now Blue and near Acc) ===== -->
    <ProgressBar
        android:id="@+id/pb_song_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="10dp"
        android:layout_marginStart="16dp"
        android:progress="0"
        android:progressTint="#2196F3"
        android:progressBackgroundTint="#44FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_game_accuracy"
        app:layout_constraintStart_toEndOf="@id/tv_game_accuracy"
        app:layout_constraintTop_toTopOf="@id/tv_game_accuracy" />

    <TextView
        android:id="@+id/tv_game_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="Score: 0"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/top_bar_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_bar_bg" />

    <!-- ===== LANES ===== -->
    <View
        android:id="@+id/lane_divider"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#33FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar_bg" />

    <!-- Left Lane Content Area -->
    <FrameLayout
        android:id="@+id/lane_left"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/lane_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar_bg" />

    <!-- Right Lane Content Area -->
    <FrameLayout
        android:id="@+id/lane_right"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/lane_divider"
        app:layout_constraintTop_toBottomOf="@id/top_bar_bg" />

    <!-- ===== TARGETS (CUBES) ===== -->
    <View
        android:id="@+id/target_left"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/target_cube_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/lane_left"
        app:layout_constraintStart_toStartOf="@id/lane_left" />

    <View
        android:id="@+id/target_right"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/target_cube_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/lane_right"
        app:layout_constraintStart_toStartOf="@id/lane_right" />

</androidx.constraintlayout.widget.ConstraintLayout>