<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/OnlineGamePage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_red">

    <!-- ===== TOP BAR ===== -->
    <View
        android:id="@+id/top_bar_bg"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#22000000"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Turn label centered -->
    <TextView
        android:id="@+id/tvTurnInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Your Turn"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/top_bar_bg"
        app:layout_constraintEnd_toStartOf="@id/btnEndGame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_bar_bg" />

    <!-- Exit button top-right -->
    <Button
        android:id="@+id/btnEndGame"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="#44000000"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="22dp"
        app:layout_constraintBottom_toBottomOf="@id/top_bar_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_bar_bg" />

    <!-- ===== TIMER + SCORE ROW ===== -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:background="#33000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="02:00"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar_bg" />

    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:background="#33000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="P1: 0 | P2: 0"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar_bg" />

    <!-- ===== QUESTION CARD ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/questionCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toTopOf="@id/answersRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTimer">

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="28dp"
            android:text="Question text goes here"
            android:textColor="#1A1A1A"
            android:textSize="20sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- ===== ANSWER BUTTONS ===== -->
    <LinearLayout
        android:id="@+id/answersRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnAnswerA"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#33000000"
            android:text="A"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#44FFFFFF"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnAnswerB"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#33000000"
            android:text="B"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#44FFFFFF"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnAnswerC"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="#33000000"
            android:text="C"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#44FFFFFF"
            app:strokeWidth="1dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>