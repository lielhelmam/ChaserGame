<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/MainPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_red"
    android:padding="20dp">

    <!-- ===== HEADER SECTION ===== -->
    <View
        android:id="@+id/header_shadow"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#33000000"
        android:layout_margin="-20dp"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_main_hitouser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:text="Hi, User"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_main_logout"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:text="Logout ⎋"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== MAIN CONTENT CARD ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/modesCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/text_main_hitouser">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Category: Rhythm -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rhythm Games"
                android:textColor="#757575"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_main_rythmgame"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/background_red"
                android:text="🎶 Rhythm Game"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <!-- Category: Trivia -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trivia Games"
                android:textColor="#757575"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_main_playagainstabot"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#444444"
                android:text="🤖 Trivia vs Bot"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btn_main_playonline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/background_red"
                android:text="🌐 Trivia Online"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btn_main_playononedevice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#444444"
                android:text="📱 Trivia 1v1 Local"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== BOTTOM TOOLS ===== -->
    <LinearLayout
        android:id="@+id/bottom_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/modesCard">

        <Button
            android:id="@+id/btn_main_leaderboards"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="🏆 Rankings"
            android:backgroundTint="#FFFFFF"
            android:textColor="@color/background_red"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btn_main_edit_profile"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#444444"
            android:text="⚙️ Edit Profile"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>