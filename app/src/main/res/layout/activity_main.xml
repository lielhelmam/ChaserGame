<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_red"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".screens.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- MAIN MODES CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/modesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:letterSpacing="0.1"
                    android:text="@string/main_choose_game_title"
                    android:textAllCaps="true"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_main_rythmgame"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="@color/background_red"
                    android:text="@string/main_rhythm_game_btn"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="20dp"
                    android:background="#EEEEEE" />

                <Button
                    android:id="@+id/btn_main_playagainstabot"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#444444"
                    android:text="@string/main_trivia_vs_bot_btn"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_main_playonline"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/background_red"
                    android:text="@string/main_trivia_online_btn"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_main_playononedevice"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#444444"
                    android:text="@string/main_trivia_local_btn"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- QUICK ACTIONS -->
        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_main_leaderboards"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#FFFFFF"
                android:text="@string/main_rankings_btn"
                android:textColor="@color/background_red"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/background_red"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btn_main_edit_profile"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#444444"
                android:text="@string/main_profile_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="18dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>