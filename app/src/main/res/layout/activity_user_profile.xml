<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_red"
    tools:context=".screens.UserProfileActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- PROFILE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_profile_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Profile"
                        android:textColor="#333333"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp"
                        android:background="#EEEEEE" />

                    <!-- USER INFO SECTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Details"
                        android:textColor="@color/background_red"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_profile_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="—"
                            android:textColor="#333333"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Address"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_profile_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="—"
                            android:textColor="#333333"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account Type"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_profile_admin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="—"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Security"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_profile_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="••••••••"
                            android:textColor="#333333"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="20dp"
                        android:background="#EEEEEE" />

                    <!-- STATS SECTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Game Statistics"
                        android:textColor="@color/background_red"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <!-- Online Wins -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌐 Online Victories"
                                android:textColor="#333333"
                                android:textStyle="bold"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_online_wins"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/background_red"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:layout_marginEnd="8dp"/>
                                <ImageButton
                                    android:id="@+id/btn_edit_online_wins"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    app:tint="#888888"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Bot Easy -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🤖 Bot Wins (Easy)"
                                android:textColor="#333333"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_bot_wins_easy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#333333"
                                    android:textSize="16sp"
                                    android:layout_marginEnd="8dp"/>
                                <ImageButton
                                    android:id="@+id/btn_edit_bot_wins_easy"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    app:tint="#888888"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Bot Normal -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🤖 Bot Wins (Normal)"
                                android:textColor="#333333"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_bot_wins_normal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#333333"
                                    android:textSize="16sp"
                                    android:layout_marginEnd="8dp"/>
                                <ImageButton
                                    android:id="@+id/btn_edit_bot_wins_normal"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    app:tint="#888888"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Bot Hard -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🤖 Bot Wins (Hard)"
                                android:textColor="#333333"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_bot_wins_hard"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#333333"
                                    android:textSize="16sp"
                                    android:layout_marginEnd="8dp"/>
                                <ImageButton
                                    android:id="@+id/btn_edit_bot_wins_hard"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    app:tint="#888888"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Local 1v1 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📱 Local 1v1 Wins"
                                android:textColor="#333333"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_one_device_wins"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#333333"
                                    android:textSize="16sp"
                                    android:layout_marginEnd="8dp"/>
                                <ImageButton
                                    android:id="@+id/btn_edit_one_device_wins"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    app:tint="#888888"/>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <ProgressBar
                android:id="@+id/profile_progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>